<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#F4F9F5">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Crear Cuenta"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Únete para mejorar tus hábitos"
        android:textSize="16sp"
        android:textColor="#666666"
        android:gravity="center"
        android:layout_marginBottom="40dp"/>

    <EditText
        android:id="@+id/correo"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Correo electrónico"
        android:inputType="textEmailAddress"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="2dp"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/contraseña"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Contraseña (mínimo 6 caracteres)"
        android:inputType="textPassword"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="2dp"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/confirma"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Confirmar contraseña"
        android:inputType="textPassword"
        android:background="#FFFFFF"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="2dp"
        android:layout_marginBottom="24dp"/>

    <CheckBox
        android:id="@+id/cbEsNutricionista"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Soy Nutricionista Profesional"
        android:textColor="#333333"
        android:textSize="16sp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/Guardar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Registrarse"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:soundEffectsEnabled="true"
        android:textStyle="bold" />

</LinearLayout>